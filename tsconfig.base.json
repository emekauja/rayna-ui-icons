{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "rayna-icons": ["./src/index.ts"],
      "rayna-icons/react": ["./react/src/index.ts"],
      "rayna-icons/vue": ["./vue/src/index.ts"],
      "rayna-icons/react-native": ["./react-native/src/index.ts"],
      "@raynaui/icons-core": ["./core/src/index.ts"],
      "@raynaui/icons-theme": ["./theme/src/index.ts"]
    }
  }
}
