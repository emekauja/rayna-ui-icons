{
  "name": "rayna-icons",
  "version": "0.1.0",
  "description": "Rayna UI icon library for React, React Native, and Vue.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emekauja/rayna-ui-icons.git"
  },
  "homepage": "https://github.com/emekauja/rayna-ui-icons",
  "bugs": {
    "url": "https://github.com/emekauja/rayna-ui-icons/issues"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "raynaui-icons",
    "rayna-icons",
    "rayna", 
    "rayna-ui-icons",
    "raynaicons",
    "rayna-ui",
    "icons",
    "icon-library",
    "react-icons",
    "react-native-icons",
    "vue-icons",
    "svg-icons",
    "design-system"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "import": "./dist/vue/index.js"
    },
    "./react-native": {
      "types": "./dist/react-native/index.d.ts",
      "react-native": "./dist/react-native/index.js",
      "import": "./dist/react-native/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "generate": "node ./core/scripts/generate-icons.mjs",
    "build": "node ./core/scripts/generate-icons.mjs && tsup",
    "build:package": "tsup",
    "build:homepage": "npm --prefix homepage run build",
    "dev": "npm --prefix homepage run dev",
    "test": "vitest run",
    "lint": "tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "react": "^18.3.1 || ^19.0.0",
    "react-native": ">=0.74.0",
    "react-native-svg": ">=15.0.0",
    "vue": "^3.5.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-native": {
      "optional": true
    },
    "react-native-svg": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.5",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/vue": "^8.1.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.1",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "jsdom": "^26.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-native": "^0.78.0",
    "react-native-svg": "^15.11.2",
    "react-test-renderer": "^19.1.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.2",
    "vitest": "^3.0.9",
    "vue": "^3.5.13"
  }
}
